{
  "manifest_version": 3,
  "name": "SGDS DOM to Figma",
  "version": "3.0.0",
  "description": "Capture full page DOM structure as JSON for import into Figma",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
